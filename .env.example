# ─── LLM (Required for full functionality) ───
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ─── Blockchain ───────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_key_here

# ─── Market Data (optional pro tier) ─────────
COINGECKO_API_KEY=

# ─── News (optional) ─────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ─── App ─────────────────────────────────────
APP_PORT=8000
DEBUG=false
SECRET_KEY=change-this-to-random-32-char-string

# ─── Database (production) ───────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cryptosentinel

# ─── Cache (production) ──────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Monitoring ──────────────────────────────
SENTRY_DSN=
